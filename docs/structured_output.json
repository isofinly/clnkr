{
  "type": "object",
  "properties": {
    "source_language": {
      "type": "string",
      "example": "ja"
    },
    "target_language": {
      "type": "string",
      "example": "en"
    },
    "total_duration_seconds": {
      "type": "number",
      "example": 1739
    },
    "speakers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "speaker_id": {
            "type": "string",
            "example": "spk_1"
          },
          "label": {
            "type": "string",
            "example": "Speaker 1"
          }
        },
        "required": ["speaker_id", "label"],
        "propertyOrdering": ["speaker_id", "label"]
      }
    },
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "start_seconds": {
            "type": "number",
            "example": 28.1
          },
          "end_seconds": {
            "type": "number",
            "example": 32.4
          },
          "raw_text": {
            "type": "string",
            "example": "感覚をシェアした"
          },
          "words": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string",
                  "example": "感覚"
                },
                "reading": {
                  "type": "string",
                  "example": "かんかく"
                },
                "romanization": {
                  "type": "string",
                  "example": "kankaku"
                }
              },
              "required": ["text", "reading", "romanization"],
              "propertyOrdering": ["text", "reading", "romanization"]
            }
          },
          "translation": {
            "type": "string",
            "example": "shared the feeling"
          },
          "speaker": {
            "type": "object",
            "properties": {
              "speaker_id": {
                "type": "string",
                "example": "spk_1"
              },
              "label": {
                "type": "string",
                "example": "Speaker 1"
              }
            },
            "required": ["speaker_id", "label"],
            "propertyOrdering": ["speaker_id", "label"]
          }
        },
        "required": [
          "id",
          "start_seconds",
          "end_seconds",
          "raw_text",
          "words",
          "translation",
          "speaker"
        ],
        "propertyOrdering": [
          "id",
          "start_seconds",
          "end_seconds",
          "raw_text",
          "words",
          "translation",
          "speaker"
        ]
      }
    }
  },
  "required": [
    "source_language",
    "target_language",
    "total_duration_seconds",
    "speakers",
    "segments"
  ],
  "propertyOrdering": [
    "source_language",
    "target_language",
    "total_duration_seconds",
    "speakers",
    "segments"
  ]
}
